---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const compare = await getCollection('compare');
const sorted = compare.sort((a, b) => +b.data.pubDate - +a.data.pubDate);
---
<BaseLayout
  title="Head-to-Head Comparisons - AI Smart Tools"
  description="Side-by-side comparisons of AI productivity tools. Winner named, with evidence."
>
  <article class="container-wide py-12 md:py-16">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 mb-3">Head-to-Head Comparisons</h1>
    <p class="text-lg text-slate-600 mb-10">{sorted.length} comparison{sorted.length === 1 ? '' : 's'}.</p>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sorted.map(post => (
        <a href={'/compare/' + post.slug} class="group rounded-xl border border-slate-200 bg-white p-6 hover:border-brand-400 hover:shadow-lg transition">
          <span class="text-xs font-semibold uppercase tracking-wider text-brand-600 mb-2 block">{post.data.category}</span>
          <h2 class="font-bold text-lg">{post.data.title}</h2>
        </a>
      ))}
    </div>
    {sorted.length === 0 && <p class="text-center text-slate-500 py-12">First comparison coming soon.</p>}
  </article>
</BaseLayout>
