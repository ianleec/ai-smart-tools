---
export interface Props {
  product: string;
  cta: string;
  url: string;
  price?: string;
  badge?: string;
}

const { product, cta, url, price, badge = 'TOP PICK' } = Astro.props;
---
<div class="my-6 rounded-xl border-2 border-brand-200 bg-gradient-to-r from-brand-50 to-white p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4">
  <div class="flex-1">
    <div class="text-xs font-bold uppercase tracking-wider text-brand-700 mb-1">{badge}</div>
    <div class="font-bold text-slate-900 text-lg mb-0.5">{product}</div>
    {price && <div class="text-sm text-slate-600">Starting at <span class="font-semibold">{price}</span></div>}
  </div>
  <a 
    href={url} 
    rel="sponsored nofollow noopener" 
    target="_blank"
    class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-700 transition shadow-sm hover:shadow"
  >
    {cta}
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
  </a>
</div>
