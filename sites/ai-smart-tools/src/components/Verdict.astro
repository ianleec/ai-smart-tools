---
export interface Props {
  winner: string;
  reason: string;
  rating?: number;
}

const { winner, reason, rating } = Astro.props;
---
<aside class="my-8 rounded-2xl border-2 border-brand-200 bg-gradient-to-br from-brand-50 to-white p-6 shadow-sm">
  <div class="flex items-start gap-3">
    <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-brand-600 text-white">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
    </div>
    <div class="flex-1">
      <div class="text-xs font-bold uppercase tracking-wider text-brand-700 mb-1">
        Our Verdict (TL;DR)
      </div>
      <h2 class="text-xl font-bold text-slate-900 mb-2">
        The winner is: {winner}
        {rating !== undefined && (
          <span class="ml-2 inline-flex items-center gap-1 text-sm font-medium text-amber-600">
            ⭐ {rating}/5
          </span>
        )}
      </h2>
      <p class="text-slate-700 leading-relaxed">{reason}</p>
    </div>
  </div>
</aside>
