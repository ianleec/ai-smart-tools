---
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/best', label: 'Best of 2026' },
  { href: '/reviews', label: 'Reviews' },
  { href: '/compare', label: 'Comparisons' },
  { href: '/guides', label: 'Guides' },
  { href: '/about', label: 'About' },
];
---
<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200">
  <div class="container-wide flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-slate-900 hover:text-brand-600 transition">
      <span class="flex items-center justify-center w-9 h-9 rounded-lg bg-brand-600 text-white text-sm font-bold">AI</span>
      <span>SmartTools</span>
    </a>
    
    <nav class="hidden md:flex items-center gap-6">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class:list={[
            "text-sm font-medium transition",
            pathname.startsWith(item.href) 
              ? "text-brand-600" 
              : "text-slate-600 hover:text-slate-900"
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    
    <div class="flex items-center gap-3">
      <a href="/rss.xml" class="hidden sm:flex items-center gap-1.5 text-sm text-slate-500 hover:text-brand-600 transition" aria-label="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      </a>
      <a href="/best" class="hidden sm:inline-flex items-center justify-center rounded-md bg-brand-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-brand-700 transition">
        Browse Best-of
      </a>
    </div>
  </div>
</header>
