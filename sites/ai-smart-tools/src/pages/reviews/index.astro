---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const reviews = await getCollection('reviews');
const sorted = reviews.sort((a, b) => +b.data.pubDate - +a.data.pubDate);
---
<BaseLayout
  title="All Reviews - AI Smart Tools"
  description="Browse our complete library of in-depth, hands-on AI tool reviews. Updated weekly."
>
  <article class="container-wide py-12 md:py-16">
    <header class="mb-10">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 mb-3">All Reviews</h1>
      <p class="text-lg text-slate-600">{sorted.length} reviews of AI productivity tools.</p>
    </header>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sorted.map(post => (
        <a href={'/reviews/' + post.slug} class="group rounded-xl border border-slate-200 bg-white p-6 hover:border-brand-400 hover:shadow-lg transition">
          <h2 class="font-bold text-lg">{post.data.title}</h2>
        </a>
      ))}
    </div>
  </article>
</BaseLayout>
