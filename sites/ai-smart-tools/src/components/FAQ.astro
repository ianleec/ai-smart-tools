---
export interface FAQItem {
  q: string;
  a: string;
}

export interface Props {
  faqs: FAQItem[];
}

const { faqs } = Astro.props;
---
{faqs.length > 0 && (
  <section class="my-10">
    <h2 class="text-2xl font-bold text-slate-900 mb-6 scroll-mt-24">
      Frequently Asked Questions
    </h2>
    <div class="space-y-3">
      {faqs.map((f, idx) => (
        <details class="group rounded-lg border border-slate-200 bg-white shadow-sm" open={idx === 0}>
          <summary class="flex items-center justify-between cursor-pointer p-4 font-semibold text-slate-900 hover:bg-slate-50 transition list-none">
            <span>{f.q}</span>
            <svg class="w-5 h-5 text-slate-400 transition group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="px-4 pb-4 text-slate-700 leading-relaxed">
            {f.a}
          </div>
        </details>
      ))}
    </div>
  </section>
)}
