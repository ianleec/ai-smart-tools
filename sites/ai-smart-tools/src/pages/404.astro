---
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page Not Found — AI Smart Tools"
  description="The page you're looking for doesn't exist."
>
  <section class="container-prose py-20 text-center">
    <h1 class="text-7xl font-bold text-slate-900 mb-4">404</h1>
    <p class="text-xl text-slate-600 mb-8">
      We couldn't find the page you were looking for.
    </p>
    <a href="/" class="inline-flex items-center justify-center rounded-lg bg-brand-600 px-5 py-3 text-base font-semibold text-white hover:bg-brand-700 transition">
      ← Back to homepage
    </a>
  </section>
</BaseLayout>
